#!/usr/bin/env bash
# run_onchange_after_generate-completions.sh — Automatically runs when the global mise lockfile changes to keep shell completions up to date.
# The embedded hash makes chezmoi re-run this script whenever the pinned global tools change.
# mise.lock hash: {{ include "dot_config/mise/mise.lock" | sha256sum }}

set -euo pipefail

DOT_BIN="${HOME}/.local/bin/dot"

if [[ -f ${DOT_BIN} ]]; then
  echo "=> Changes in mise tools detected. Regenerating Fish autocompletions..."
  exec "${DOT_BIN}" completion
else
  echo "=> Warning: dot CLI not found at ${DOT_BIN}. Skipping completions generation."
fi
