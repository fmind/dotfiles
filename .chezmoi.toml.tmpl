{{- $interactive := stdinIsATTY -}}

{{- $git_name := "Médéric Hurier (Fmind)" -}}
{{- if hasKey . "git_name" -}}
{{-   $git_name = .git_name -}}
{{- else if $interactive -}}
{{-   $git_name = promptString "What is your Git name" $git_name -}}
{{- end -}}

{{- $git_email := "github@fmind.dev" -}}
{{- if hasKey . "git_email" -}}
{{-   $git_email = .git_email -}}
{{- else if $interactive -}}
{{-   $git_email = promptString "What is your Git email address" $git_email -}}
{{- end -}}

{{- $github_user := "fmind" -}}
{{- if hasKey . "github_user" -}}
{{-   $github_user = .github_user -}}
{{- else if $interactive -}}
{{-   $github_user = promptString "What is your GitHub username" $github_user -}}
{{- end -}}

encryption = "age"

[data]
    git_name = {{ $git_name | quote }}
    git_email = {{ $git_email | quote }}
    github_user = {{ $github_user | quote }}

[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = "age1uvmlyuvm070d22xtmsadg9a0ucw49fyn4fx0fkd805lp3kd6zy0q745paz"

[cd]
    command = "fish"

[edit]
    command = "nvim"
    apply = true

[diff]
    pager = "cat"

[merge]
    command = "nvim"
    args = [
        "-d",
        "{{`{{ .Destination }}`}}",
        "{{`{{ .Source }}`}}",
        "{{`{{ .Target }}`}}"
    ]
