{
  "agents": {
    "overrides": {
      "browser_agent": {
        "enabled": true
      }
    },
    "browser": {
      "sessionMode": "persistent",
      "visualModel": "gemini-2.5-computer-use-preview-10-2025"
    }
  },
  "general": {
    "respectGitIgnore": true,
    "defaultApprovalMode": "auto_edit",
    "enableNotifications": true,
    "preferredEditor": "antigravity",
    "vimMode": true,
    "checkpointing": {
      "enabled": true
    },
    "plan": {
      "enabled": true,
      "modelRouting": true
    }
  },
  "experimental": {
    "enableAgents": true,
    "memoryManager": true,
    "modelSteering": true,
    "taskTracker": true,
    "worktrees": true
  },
  "modelConfigs": {
    "defaultModel": "auto-gemini-3"
  },
  "security": {
    "authType": "oauth-personal",
    "autoAddToPolicyByDefault": true,
    "enablePermanentToolApproval": true,
    "environmentVariableRedaction": {},
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "Google Code",
    "escapePastedAtSymbols": true,
    "hideContextPercentage": false,
    "hideSandboxStatus": true,
    "hideBanner": true,
    "hideTips": true,
    "hideWindowTitle": true,
    "loadingPhrases": "off",
    "showCitations": true,
    "showModelInfoInChat": true,
    "useAlternateBuffer": false
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  }
}
