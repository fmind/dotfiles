{
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    },
    "fileName": [
      "AGENTS.md",
      "GEMINI.md",
      "README.md"
    ]
  },
  "experimental": {
    "enableAgents": true,
    "memoryManager": true,
    "modelSteering": true,
    "taskTracker": true,
    "topicUpdateNarration": true,
    "worktrees": true
  },
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "defaultApprovalMode": "auto_edit",
    "preferredEditor": "antigravity",
    "enableNotifications": true
  },
  "ide": {
    "enabled": true
  },
  "model": {
    "name": "auto-gemini-3"
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "autoAddToPolicyByDefault": true,
    "enablePermanentToolApproval": true,
    "environmentVariableRedaction": {
      "enabled": true
    }
  },
  "ui": {
    "escapePastedAtSymbols": true,
    "footer": {
      "hideContextPercentage": false,
      "hideSandboxStatus": true
    },
    "hideBanner": true,
    "hideTips": true,
    "hideWindowTitle": true,
    "loadingPhrases": "off",
    "showCitations": false,
    "showHomeDirectoryWarning": false,
    "showModelInfoInChat": true,
    "theme": "Google Code",
    "useAlternateBuffer": true
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  }
}
