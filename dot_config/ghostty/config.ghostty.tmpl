# Appearance
macos-titlebar-style = hidden
theme = "Catppuccin Mocha"

# Font Configuration
font-family = "FiraCode Nerd Font Mono"
font-feature = -calt
font-feature = -liga
font-size = 13

# Cursor
cursor-style = block
cursor-style-blink = false

# macOS Specific
macos-option-as-alt = left

# Quality of Life
clipboard-paste-protection = false
copy-on-select = clipboard
mouse-hide-while-typing = true

# Launch fish through the mise shim because GUI apps on macOS do not inherit
# the shell PATH that normally exposes `fish`.
command = {{ joinPath .chezmoi.homeDir ".local/share/mise/shims/fish" | quote }}

# Zellij & Shell Integration
confirm-close-surface = false
shell-integration-features = true

# Disable bells to avoid annoyance
bell-features = false
