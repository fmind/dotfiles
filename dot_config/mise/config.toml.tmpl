[settings]
aqua.cosign = false
aqua.github_attestations = false
aqua.minisign = false
aqua.slsa = false
env_cache = true
github.github_attestations = false
github.slsa = false
github_attestations = false
lockfile = true
lockfile_platforms = ["linux-x64", "macos-arm64"]
minimum_release_age = "0d"
slsa = false

[settings.hook_env]
chpwd_only = true

