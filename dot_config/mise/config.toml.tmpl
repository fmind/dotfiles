[tools."github:googleworkspace/cli"]
# v0.22.5's musl-labeled x64 asset is glibc-linked and requires GLIBC 2.39.
# Keep every platform on the last verified portable release so the shared lockfile
# cannot resolve Linux back to the broken version through a newer macOS entry.
version = "0.22.4" # Google Workspace CLI (gws)

[tools."github:googleworkspace/cli".platforms]
linux-x64 = { asset_pattern = "*x86_64-unknown-linux-musl*" }
linux-arm64 = { asset_pattern = "*aarch64-unknown-linux-musl*" }
macos-x64 = { asset_pattern = "*x86_64-apple-darwin*" }
macos-arm64 = { asset_pattern = "*aarch64-apple-darwin*" }
