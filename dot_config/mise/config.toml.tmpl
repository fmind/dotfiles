chezmoi = "latest"
d2 = "latest"
delta = "latest"
dive = "latest"
doggo = "latest"
duf = "latest"
dust = "latest"
eza = "latest"
fastfetch = "latest"
fd = "latest"
firebase = "latest"
fzf = "latest"
gcloud = "latest"
gh = "latest"
{{- if eq .chezmoi.os "linux" }}
{{-   if eq .chezmoi.arch "amd64" }}
"github:googleworkspace/cli" = { version = "latest", asset_pattern = "*x86_64-unknown-linux-musl*" }
{{-   else if eq .chezmoi.arch "arm64" }}
"github:googleworkspace/cli" = { version = "latest", asset_pattern = "*aarch64-unknown-linux-musl*" }
{{-   else }}
"github:googleworkspace/cli" = { version = "latest", asset_pattern = "*linux-musl*" }
{{-   end }}
{{- else }}
"github:googleworkspace/cli" = "latest"
{{- end }}
git-lfs = "latest"
gitleaks = "latest"
