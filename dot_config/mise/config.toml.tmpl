"npm:@google/clasp" = "latest"
"npm:@google/gemini-cli" = "latest"
"npm:@google/jules" = "latest"
"npm:@mermaid-js/mermaid-cli" = "latest"
"npm:lighthouse" = "latest"
"npm:neovim" = "latest"
"npm:pnpm" = "latest"
"npm:tsx" = "latest"
"npm:typescript" = "latest"
"pipx:ptpython" = "latest"
"pipx:pynvim" = "latest"
age = "latest"
ast-grep = "latest"
atuin = "latest"
