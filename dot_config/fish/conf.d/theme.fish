# Syntax highlighting (Tokyo Night Moon)
set -g fish_color_normal c8d3f5
set -g fish_color_command 82aaff
set -g fish_color_keyword ff757f
set -g fish_color_quote c3e88d
set -g fish_color_redirection c099ff
set -g fish_color_end ff966c
set -g fish_color_error ff757f
set -g fish_color_param 828bb8
set -g fish_color_comment 636da6
set -g fish_color_selection --background=2d3f76
set -g fish_color_search_match --background=2d3f76
set -g fish_color_operator c099ff
set -g fish_color_escape ff966c
set -g fish_color_autosuggestion 636da6
set -g fish_color_cancel ff757f
set -g fish_color_valid_path --underline

# Prompt identity
set -g fish_color_cwd ffc777
set -g fish_color_cwd_root ff757f
set -g fish_color_user 86e1fc
set -g fish_color_host 82aaff
set -g fish_color_host_remote c3e88d

# Completion pager
set -g fish_pager_color_progress 636da6
set -g fish_pager_color_prefix c099ff --bold
set -g fish_pager_color_completion c8d3f5
set -g fish_pager_color_description 636da6
set -g fish_pager_color_selected_background --background=2d3f76
