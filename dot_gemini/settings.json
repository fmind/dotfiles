{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "session-log",
            "type": "command",
            "command": "dot agent session agy",
            "timeout": 30000,
            "description": "Log session to ~/.agents/sessions/ in unified JSONL format"
          }
        ]
      }
    ]
  }
}
