#!/usr/bin/env bash
set -eu

{{ if eq .chezmoi.os "linux" -}}
if [ -f /etc/debian_version ]; then
    if [ "$(id -u)" -eq 0 ]; then
        echo "[Chezmoi] Installing Debian packages..."
        apt-get update -qq
        apt-get install -yq {{ range .linux_packages }} {{ . }}{{ end }}
    elif command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
        echo "[Chezmoi] Installing Debian packages..."
        sudo apt-get update -qq
        sudo apt-get install -yq {{ range .linux_packages }} {{ . }}{{ end }}
    else
        echo "[Chezmoi] Skipping Debian packages: non-interactive sudo unavailable."
    fi
fi
{{ else if eq .chezmoi.os "darwin" -}}
if command -v brew >/dev/null 2>&1; then
    echo "[Chezmoi] Installing macOS packages..."
    brew install -q {{ range .mac_packages }} {{ . }}{{ end }}
fi
{{ end -}}
