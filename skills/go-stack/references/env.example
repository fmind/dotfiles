ENVIRONMENT=development
# Web projects: HTTP listen port (config.go defaults to 8080 when unset).
# PORT=8080
# Tracing (web/agent): set an OTLP endpoint to enable OpenTelemetry span export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Agents authenticate to Vertex AI via ADC (`gcloud auth application-default login`):
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=global
